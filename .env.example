# Required. Shared password for the login gate. No default — the app refuses to start
# without this set.
GAME_PASSWORD=change-me

# Optional, shown with their defaults.
PORT=3000
CACHE_DIR=/var/cache/game
MAX_POSTS=150
SESSION_TTL_MIN=30

# Path to the Instaloader executable. setup-pi.sh installs Instaloader into a
# venv at <project>/venv (Debian/Raspberry Pi OS blocks system-wide pip
# installs) and fills this in automatically with the real absolute path. Only
# set it yourself if you installed Instaloader some other way.
INSTALOADER_BIN=/home/pi/gramle/venv/bin/instaloader

# Optional: authenticated scraping. Instagram increasingly 403s anonymous
# requests outright, even to public profiles. If Instaloader keeps getting
# blocked, create a THROWAWAY Instagram account (never your main one — this
# account risks getting flagged/banned for scraping) and set:
#
#   IG_LOGIN_USER=your_throwaway_username
#
# Then, ONE TIME, log in interactively yourself from the Pi's own shell —
# this app never sees or stores the password, only the session file that
# comes out of it:
#
#   mkdir -p ~/.config/gramle
#   /path/to/venv/bin/instaloader --login=your_throwaway_username \
#     --sessionfile=~/.config/gramle/instaloader-session
#
# (It will prompt for the password, and possibly a 2FA/checkpoint code,
# right there in your terminal.) Leave both vars unset to keep scraping
# anonymously.
IG_LOGIN_USER=
IG_SESSION_FILE=
