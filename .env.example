# Required. Shared password for the login gate. No default — the app refuses to start
# without this set.
GAME_PASSWORD=change-me

# Optional, shown with their defaults.
PORT=3000
CACHE_DIR=/var/cache/game
MAX_POSTS=150
SESSION_TTL_MIN=30

# Path to the Instaloader executable. setup-pi.sh installs Instaloader into a
# venv at <project>/venv (Debian/Raspberry Pi OS blocks system-wide pip
# installs) and fills this in automatically with the real absolute path. Only
# set it yourself if you installed Instaloader some other way.
INSTALOADER_BIN=/home/pi/gramle/venv/bin/instaloader
